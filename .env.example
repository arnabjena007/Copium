# ──────────────────────────────────────────────────────────
# CloudCFO — Environment Variables
# ──────────────────────────────────────────────────────────
# Copy this file to .env and fill in your real values:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Mac/Linux)

# ── REQUIRED: Slack ───────────────────────────────────────
# Get a webhook URL at: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Get a signing secret from your Slack App settings
SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Optional Slack overrides
SLACK_CHANNEL=#cloud-costs
SLACK_BOT_NAME=CloudCFO
SLACK_BOT_EMOJI=:cloud:
SLACK_TIMEOUT_SECONDS=10
SLACK_MAX_RETRIES=3

# ── REQUIRED: AWS ─────────────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1

# ── Anomaly Detection Tuning ──────────────────────────────
ANOMALY_BASELINE_DAYS=7
ANOMALY_DATA_LAG_DAYS=1
ANOMALY_MINIMUM_DAILY_COST=10
ANOMALY_MINIMUM_COST_INCREASE=5
ANOMALY_SPIKE_MULTIPLIER=1.5
ANOMALY_SCORE_SCALE_DOLLARS=100
